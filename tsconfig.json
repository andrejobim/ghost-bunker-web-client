{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "types": ["vitest/globals"],
    "baseUrl": "."
  },
  "include": ["src", "proto", "buf.gen.yaml", "buf.yaml", "vite.config.ts", "vitest.config.ts"]
}

